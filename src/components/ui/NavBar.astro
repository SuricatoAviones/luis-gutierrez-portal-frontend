---
// src/components/ui/NavBar.astro
const navLinks = [
  { href: "/#sobre-mi", label: "Sobre mí" },
  { href: "/#habilidades", label: "Habilidades" },
  { href: "/#portafolio", label: "Portafolio" },
  { href: "/#experiencia", label: "Experiencia" },
  { href: "/blog", label: "Blog" },
];

const currentPath = Astro.url.pathname;
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav
    class="max-w-content mx-auto px-6 lg:px-10 flex items-center justify-between h-18"
  >
    <!-- Logo -->
    <a
      href="/"
      class="font-headline text-xl font-semibold tracking-tight text-on-surface hover:text-primary transition-colors duration-200"
    >
      LG<span class="text-primary">.</span>
    </a>

    <!-- Links desktop -->
    <ul class="hidden md:flex items-center gap-8">
      {
        navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`font-body text-sm font-medium transition-colors duration-200
              ${
                currentPath === href ||
                (href !== "/" && currentPath.startsWith(href.split("#")[0]))
                  ? "text-primary"
                  : "text-on-surface-variant hover:text-on-surface"
              }`}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Right side: Theme toggle + CTA -->
    <div class="flex items-center gap-3">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        aria-label="Cambiar tema"
        class="w-9 h-9 rounded-full flex items-center justify-center text-on-surface-variant hover:text-on-surface hover:bg-surface-high transition-all duration-200"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          class="w-5 h-5 hidden dark-icon"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"
          ></path>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          class="w-5 h-5 light-icon"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"
          ></path>
        </svg>
      </button>

      <!-- CTA desktop -->
      <a
        href="/contacto"
        class="hidden md:inline-flex items-center gap-2 px-5 py-2 bg-primary text-on-primary text-sm font-medium rounded-md hover:opacity-90 transition-opacity duration-200"
      >
        Hablemos
      </a>

      <!-- Hamburger mobile -->
      <button
        id="menu-toggle"
        aria-label="Abrir menú"
        class="md:hidden flex flex-col gap-1.5 p-2"
      >
        <span
          class="menu-line block w-5 h-px bg-on-surface transition-all duration-300 origin-center"
        ></span>
        <span
          class="menu-line block w-5 h-px bg-on-surface transition-all duration-300 origin-center"
        ></span>
        <span
          class="menu-line block w-5 h-px bg-on-surface transition-all duration-300 origin-center"
        ></span>
      </button>
    </div>
  </nav>

  <!-- Menú mobile -->
  <div
    id="mobile-menu"
    class="md:hidden hidden flex-col bg-surface-container px-6 pb-6 pt-4 gap-4"
  >
    {
      navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="font-body text-base font-medium text-on-surface-variant hover:text-on-surface transition-colors py-1"
        >
          {label}
        </a>
      ))
    }
    <a
      href="/contacto"
      class="mt-2 inline-flex items-center justify-center px-4 py-2.5 bg-primary text-on-primary text-sm font-medium rounded-md"
    >
      Hablemos
    </a>
  </div>
</header>

<!-- Offset para el navbar fijo -->
<div class="h-18"></div>

<script>
  // ── Scroll: glassmorphism al bajar ──
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("glass", "shadow-sm");
    } else {
      navbar?.classList.remove("glass", "shadow-sm");
    }
  });

  // ── Theme toggle ──
  const toggle = document.getElementById("theme-toggle");
  const root = document.documentElement;

  function updateIcons() {
    const isDark =
      root.classList.contains("dark") ||
      (!root.classList.contains("light") &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);
    document
      .querySelectorAll(".dark-icon")
      .forEach((el) => el.classList.toggle("hidden", !isDark));
    document
      .querySelectorAll(".light-icon")
      .forEach((el) => el.classList.toggle("hidden", isDark));
  }

  updateIcons();

  toggle?.addEventListener("click", () => {
    const isDark =
      root.classList.contains("dark") ||
      (!root.classList.contains("light") &&
        window.matchMedia("(prefers-color-scheme: dark)").matches);

    if (isDark) {
      root.classList.remove("dark");
      root.classList.add("light");
      localStorage.setItem("theme", "light");
    } else {
      root.classList.remove("light");
      root.classList.add("dark");
      localStorage.setItem("theme", "dark");
    }
    updateIcons();
  });

  // ── Hamburger toggle ──
  const menuBtn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const lines = document.querySelectorAll(".menu-line");
  let open = false;

  menuBtn?.addEventListener("click", () => {
    open = !open;
    menu?.classList.toggle("hidden", !open);
    menu?.classList.toggle("flex", open);
    if (open) {
      lines[0]?.classList.add("rotate-45", "translate-y-[0.375rem]");
      lines[1]?.classList.add("opacity-0");
      lines[2]?.classList.add("-rotate-45", "-translate-y-[0.375rem]");
    } else {
      lines[0]?.classList.remove("rotate-45", "translate-y-[0.375rem]");
      lines[1]?.classList.remove("opacity-0");
      lines[2]?.classList.remove("-rotate-45", "-translate-y-[0.375rem]");
    }
  });

  menu?.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      open = false;
      menu.classList.add("hidden");
      menu.classList.remove("flex");
    });
  });
</script>
