---
// src/components/ui/Footer.astro
const year = new Date().getFullYear();

const socialLinks = [
  { href: "https://github.com/SuricatoAviones", label: "GitHub" },
  { href: "https://www.linkedin.com/in/luis-angel-gutierrez-b6a004187/", label: "LinkedIn" },
];
---

<footer class="bg-surface-container">
  <div class="max-w-content mx-auto px-6 lg:px-10 py-12">
    <div
      class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6"
    >
      <!-- Logo + tagline -->
      <div>
        <a
          href="/"
          class="font-headline text-xl font-semibold text-on-surface hover:text-primary transition-colors"
        >
          LG<span class="text-primary">.</span>
        </a>
        <p class="mt-1 text-sm text-on-surface-variant">
          Ingeniero de Sistemas · Construyendo con propósito.
        </p>
      </div>

      <!-- Links sociales -->
      <div class="flex items-center gap-6">
        {
          socialLinks.map(({ href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-on-surface-variant hover:text-primary transition-colors duration-200"
            >
              {label}
            </a>
          ))
        }
      </div>
    </div>

    <!-- Línea inferior -->
    <div
      class="mt-8 pt-6 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2"
      style="border-top: 1px solid color-mix(in srgb, var(--outline-variant) 30%, transparent);"
    >
      <p class="text-xs text-on-surface-variant">
        © {year} Luis Gutierrez. Todos los derechos reservados.
      </p>
      <p class="text-xs text-on-surface-variant">
        Construido con <span class="text-primary">Astro</span> + <span
          class="text-primary">Tailwind</span
        >
      </p>
    </div>
  </div>
</footer>
