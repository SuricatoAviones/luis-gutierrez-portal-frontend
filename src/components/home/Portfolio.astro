---
// src/components/home/Portfolio.astro
import { parseTechs } from '../../lib/wordpress';
import type { Project } from '../../lib/wordpress';

const wpApiBaseRaw =
  import.meta.env.PUBLIC_WP_API_URL ?? import.meta.env.WP_API_URL ?? '/wp-json';
const wpApiBase = wpApiBaseRaw.replace(/\/$/, '');
const projects: Project[] = [];
---

<section id="portafolio" class="py-24 lg:py-32">
  <div class="max-w-content mx-auto px-6 lg:px-10">

    <!-- Encabezado de sección -->
    <div class="flex items-center justify-between mb-16 reveal">
      <div class="flex items-center gap-4">
        <span class="font-mono text-2xs text-primary uppercase tracking-widest">03</span>
        <span class="block w-8 h-px bg-primary"></span>
        <h2 class="font-headline text-3xl lg:text-4xl font-semibold text-on-surface">Proyectos Seleccionados</h2>
      </div>
    </div>

    <!-- Grid de proyectos -->
    <div
      id="portfolio-grid"
      class="grid grid-cols-1 md:grid-cols-2 gap-6"
      data-api-base={wpApiBase}
    >
      {projects.map((project, i) => {
        const techs = parseTechs(project.acf.technologies);
        const delay = (i % 2) * 100;

        return (
          <article
            class="reveal group relative flex flex-col bg-surface-low rounded-xl overflow-hidden hover:bg-surface-highest transition-all duration-300 hover:-translate-y-1 ghost-border"
            style={`animation-delay: ${delay}ms`}
          >
            <!-- Imagen / Placeholder -->
            <div class="relative w-full aspect-video bg-surface-container overflow-hidden">
              {project.acf.featured_image ? (
                <img
                  src={project.acf.featured_image}
                  alt={project.title.rendered}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="font-headline text-5xl font-bold text-primary/20">
                    {project.title.rendered.charAt(0)}
                  </span>
                </div>
              )}
              <!-- Badge categoría -->
              <span class="absolute top-4 left-4 font-mono text-2xs uppercase tracking-wider bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full">
                {project.acf.category}
              </span>
              <!-- Badge año -->
              <span class="absolute top-4 right-4 font-mono text-2xs uppercase tracking-wider bg-surface-highest text-on-surface-variant px-3 py-1 rounded-full">
                {project.acf.year}
              </span>
            </div>

            <!-- Contenido -->
            <div class="flex flex-col flex-1 p-6">
              <h3 class="font-headline text-xl font-semibold text-on-surface mb-2 group-hover:text-primary transition-colors">
                {project.title.rendered}
              </h3>
              <p class="text-sm text-on-surface-variant leading-relaxed flex-1 mb-5">
                {project.acf.description}
              </p>

              <!-- Stack de tecnologías -->
              <div class="flex flex-wrap gap-2 mb-5">
                {techs.map((tech) => (
                  <span class="font-mono text-2xs text-on-surface-variant bg-surface-high px-2.5 py-1 rounded-full">
                    {tech}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex items-center gap-4 pt-4"
                   style="border-top: 1px solid color-mix(in srgb, var(--outline-variant) 20%, transparent);">
                {project.acf.project_url && project.acf.project_url !== '#' && (
                  <a
                    href={project.acf.project_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-sm font-medium text-on-surface hover:text-primary transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                    Demo en vivo
                  </a>
                )}
                {project.acf.github_url && project.acf.github_url !== '#' && (
                  <a
                    href={project.acf.github_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-1.5 text-sm text-on-surface-variant hover:text-on-surface transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.38.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02.01 2.04.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z" />
                    </svg>
                    GitHub
                  </a>
                )}
              </div>
            </div>
          </article>
        );
      })}
    </div>

    <p
      id="portfolio-feedback"
      class="hidden mt-8 rounded-xl border border-outline-variant/40 bg-surface-low px-4 py-3 text-sm text-on-surface-variant"
      aria-live="polite"
    ></p>
  </div>
</section>

<script>
  type ProjectItem = {
    title?: { rendered?: string };
    acf?: {
      project_url?: string;
      github_url?: string;
      description?: string;
      technologies?: string;
      featured_image?: string;
      year?: string;
      category?: string;
    };
  };

  const portfolioGrid = document.getElementById('portfolio-grid');
  const portfolioFeedback = document.getElementById('portfolio-feedback');

  const setFeedback = (message: string, isError = false) => {
    if (!portfolioFeedback) return;

    portfolioFeedback.textContent = message;
    portfolioFeedback.classList.remove('hidden');

    if (isError) {
      portfolioFeedback.style.borderColor =
        'color-mix(in srgb, var(--error) 35%, transparent)';
      portfolioFeedback.style.color = 'var(--error)';
      return;
    }

    portfolioFeedback.style.borderColor = '';
    portfolioFeedback.style.color = '';
  };

  const clearFeedback = () => {
    if (!portfolioFeedback) return;
    portfolioFeedback.classList.add('hidden');
    portfolioFeedback.textContent = '';
    portfolioFeedback.style.borderColor = '';
    portfolioFeedback.style.color = '';
  };

  const splitTechs = (value: unknown): string[] =>
    String(value ?? '')
      .split(',')
      .map((tech) => tech.trim())
      .filter(Boolean);

  const createLink = (
    href: string,
    label: string,
    className: string,
    iconSvg: string,
    extra: Record<string, string> = {},
  ) => {
    const link = document.createElement('a');
    link.href = href;
    link.target = '_blank';
    link.rel = 'noopener noreferrer';
    link.className = className;
    Object.entries(extra).forEach(([k, v]) => link.setAttribute(k, String(v)));
    link.innerHTML = `${iconSvg}<span>${label}</span>`;
    return link;
  };

  const createProjectCard = (project: ProjectItem, index: number) => {
    const techs = splitTechs(project?.acf?.technologies);
    const delay = (index % 2) * 100;

    const article = document.createElement('article');
    article.className =
      'reveal group relative flex flex-col bg-surface-low rounded-xl overflow-hidden hover:bg-surface-highest transition-all duration-300 hover:-translate-y-1 ghost-border';
    article.style.animationDelay = `${delay}ms`;

    const media = document.createElement('div');
    media.className = 'relative w-full aspect-video bg-surface-container overflow-hidden';

    if (project?.acf?.featured_image) {
      const image = document.createElement('img');
      image.src = project.acf.featured_image;
      image.alt = project?.title?.rendered ?? 'Proyecto';
      image.className = 'w-full h-full object-cover transition-transform duration-500 group-hover:scale-105';
      image.loading = 'lazy';
      media.appendChild(image);
    } else {
      const fallback = document.createElement('div');
      fallback.className = 'w-full h-full flex items-center justify-center';

      const initial = document.createElement('span');
      initial.className = 'font-headline text-5xl font-bold text-primary/20';
      initial.textContent = (project?.title?.rendered ?? 'P').charAt(0);

      fallback.appendChild(initial);
      media.appendChild(fallback);
    }

    const categoryBadge = document.createElement('span');
    categoryBadge.className =
      'absolute top-4 left-4 font-mono text-2xs uppercase tracking-wider bg-secondary-container text-on-secondary-container px-3 py-1 rounded-full';
    categoryBadge.textContent = project?.acf?.category ?? 'Proyecto';

    const yearBadge = document.createElement('span');
    yearBadge.className =
      'absolute top-4 right-4 font-mono text-2xs uppercase tracking-wider bg-surface-highest text-on-surface-variant px-3 py-1 rounded-full';
    yearBadge.textContent = project?.acf?.year ?? '';

    media.append(categoryBadge, yearBadge);

    const body = document.createElement('div');
    body.className = 'flex flex-col flex-1 p-6';

    const titleText = String(project?.title?.rendered ?? '').trim() || 'Proyecto';

    const title = document.createElement('h3');
    title.className =
      'font-headline text-xl font-semibold text-on-surface mb-2 group-hover:text-primary transition-colors';
    title.textContent = titleText;

    const desc = document.createElement('p');
    desc.className = 'text-sm text-on-surface-variant leading-relaxed flex-1 mb-5';
    desc.textContent =
      String(project?.acf?.description ?? '').trim() ||
      'Proyecto en actualización. Pronto más detalles.';

    const techWrap = document.createElement('div');
    techWrap.className = 'flex flex-wrap gap-2 mb-5';
    techs.forEach((tech) => {
      const chip = document.createElement('span');
      chip.className = 'font-mono text-2xs text-on-surface-variant bg-surface-high px-2.5 py-1 rounded-full';
      chip.textContent = tech;
      techWrap.appendChild(chip);
    });

    const links = document.createElement('div');
    links.className = 'flex items-center gap-4 pt-4';
    links.style.borderTop =
      '1px solid color-mix(in srgb, var(--outline-variant) 20%, transparent)';

    if (project?.acf?.project_url && project.acf.project_url !== '#') {
      links.appendChild(
        createLink(
          project.acf.project_url,
          'Demo en vivo',
          'flex items-center gap-1.5 text-sm font-medium text-on-surface hover:text-primary transition-colors',
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>',
        ),
      );
    }

    if (project?.acf?.github_url && project.acf.github_url !== '#') {
      links.appendChild(
        createLink(
          project.acf.github_url,
          'GitHub',
          'flex items-center gap-1.5 text-sm text-on-surface-variant hover:text-on-surface transition-colors',
          '<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.21 11.38.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.5 1 .11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02.01 2.04.14 3 .4 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12c0-6.63-5.37-12-12-12z" /></svg>',
        ),
      );
    }

    body.append(title, desc, techWrap, links);
    article.append(media, body);

    return article;
  };

  const loadProjects = async () => {
    const apiBase = portfolioGrid?.getAttribute('data-api-base')?.replace(/\/$/, '');
    if (!portfolioGrid) return;

    if (!apiBase) {
      setFeedback('No se pudo obtener la configuracion de la API para proyectos.', true);
      return;
    }

    try {
      const response = await fetch(
        `${apiBase}/wp/v2/portfolio?per_page=100&_fields=id,title,acf&acf_format=standard`,
      );
      if (!response.ok) {
        portfolioGrid.innerHTML = '';
        setFeedback('Hubo un fallo cargando los proyectos desde la API.', true);
        return;
      }

      const projects = (await response.json()) as ProjectItem[];
      if (!Array.isArray(projects) || projects.length === 0) {
        portfolioGrid.innerHTML = '';
        setFeedback('No hay proyectos disponibles en este momento.');
        return;
      }

      portfolioGrid.innerHTML = '';
      projects.forEach((project: ProjectItem, i: number) => {
        portfolioGrid.appendChild(createProjectCard(project, i));
      });

      clearFeedback();
    } catch {
      portfolioGrid.innerHTML = '';
      setFeedback('Hubo un fallo cargando los proyectos desde la API.', true);
    }
  };

  loadProjects();
</script>