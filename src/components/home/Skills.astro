---
// src/components/home/Skills.astro
import type { Skill } from '../../lib/wordpress';

const wpApiBaseRaw =
  import.meta.env.PUBLIC_WP_API_URL ?? import.meta.env.WP_API_URL ?? '/wp-json';
const wpApiBase = wpApiBaseRaw.replace(/\/$/, '');

const fallbackSkills: Record<string, Skill[]> = {
  Frontend: [
    { id: 1, title: { rendered: 'React' },      acf: { level: 90, category: 'Frontend', icon: '' } },
    { id: 2, title: { rendered: 'Next.js' },    acf: { level: 85, category: 'Frontend', icon: '' } },
    { id: 3, title: { rendered: 'TypeScript' }, acf: { level: 80, category: 'Frontend', icon: '' } },
    { id: 4, title: { rendered: 'Tailwind CSS'},acf: { level: 95, category: 'Frontend', icon: '' } },
    { id: 5, title: { rendered: 'Astro' },      acf: { level: 75, category: 'Frontend', icon: '' } },
  ],
  Backend: [
    { id: 6, title: { rendered: 'Node.js' },    acf: { level: 85, category: 'Backend', icon: '' } },
    { id: 7, title: { rendered: 'Express' },    acf: { level: 80, category: 'Backend', icon: '' } },
    { id: 8, title: { rendered: 'WordPress' },  acf: { level: 90, category: 'Backend', icon: '' } },
    { id: 9, title: { rendered: 'REST APIs' },  acf: { level: 88, category: 'Backend', icon: '' } },
  ],
  'Base de Datos': [
    { id: 10, title: { rendered: 'MySQL' },     acf: { level: 80, category: 'Base de Datos', icon: '' } },
    { id: 11, title: { rendered: 'PostgreSQL' },acf: { level: 75, category: 'Base de Datos', icon: '' } },
    { id: 12, title: { rendered: 'MongoDB' },   acf: { level: 70, category: 'Base de Datos', icon: '' } },
  ],
  DevOps: [
    { id: 13, title: { rendered: 'Git / GitHub' },acf: { level: 90, category: 'DevOps', icon: '' } },
    { id: 14, title: { rendered: 'Docker' },      acf: { level: 70, category: 'DevOps', icon: '' } },
    { id: 15, title: { rendered: 'Vercel' },      acf: { level: 85, category: 'DevOps', icon: '' } },
  ],
};

let skillsByCategory = fallbackSkills;

const categories = Object.keys(skillsByCategory);
---

<section
  id="habilidades"
  class="py-24 lg:py-32 bg-surface-container"
  data-api-base={wpApiBase}
>
  <div class="max-w-content mx-auto px-6 lg:px-10">

    <!-- Encabezado de sección -->
    <div class="flex items-center gap-4 mb-16 reveal">
      <span class="font-mono text-2xs text-primary uppercase tracking-widest">02</span>
      <span class="block w-8 h-px bg-primary"></span>
      <h2 class="font-headline text-3xl lg:text-4xl font-semibold text-on-surface">Habilidades</h2>
    </div>

    <!-- Tabs de categorías -->
    <div class="flex flex-wrap gap-2 mb-12 reveal" id="skill-tabs">
      {categories.map((cat, i) => (
        <button
          data-category={cat}
          class={`skill-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 ${
            i === 0
              ? 'bg-secondary-container text-on-secondary-container'
              : 'bg-surface-high text-on-surface-variant hover:bg-surface-highest hover:text-on-surface'
          }`}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Grillas de skills por categoría -->
    {categories.map((cat, i) => (
      <div
        data-panel={cat}
        class={`skill-panel ${i !== 0 ? 'hidden' : ''} grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4`}
      >
        {skillsByCategory[cat].map((skill, j) => (
          <div
            class="reveal group bg-surface-low hover:bg-surface-highest rounded-xl p-5 transition-all duration-300 ghost-border"
            style={`animation-delay: ${j * 60}ms`}
          >
            <div class="flex items-center justify-between mb-3">
              <span class="font-body text-sm font-medium text-on-surface">
                {skill.title.rendered}
              </span>
              <span class="font-mono text-xs text-primary">{skill.acf.level}%</span>
            </div>
            <!-- Barra de nivel -->
            <div class="h-1 bg-outline-variant/20 rounded-full overflow-hidden">
              <div
                class="skill-bar h-full bg-primary rounded-full origin-left scale-x-0 transition-transform duration-700"
                style={`--level: ${skill.acf.level / 100}; transition-timing-function: var(--ease-expo);`}
              ></div>
            </div>
          </div>
        ))}
      </div>
    ))}
  </div>
</section>

<script>
  type SkillItem = {
    title?: { rendered?: string };
    acf?: { category?: string; level?: number };
  };

  const section = document.getElementById('habilidades');
  const tabContainer = document.getElementById('skill-tabs');

  const bindTabs = () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.skill-tab');
    const panels = document.querySelectorAll<HTMLDivElement>('.skill-panel');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const cat = tab.dataset.category;

        tabs.forEach((t) => {
          t.classList.remove('bg-secondary-container', 'text-on-secondary-container');
          t.classList.add('bg-surface-high', 'text-on-surface-variant');
        });
        tab.classList.add('bg-secondary-container', 'text-on-secondary-container');
        tab.classList.remove('bg-surface-high', 'text-on-surface-variant');

        panels.forEach((panel) => {
          panel.classList.toggle('hidden', panel.dataset.panel !== cat);
        });

        animateBars();
      });
    });
  };

  function animateBars() {
    document.querySelectorAll<HTMLDivElement>('.skill-bar:not([data-animated])').forEach((bar) => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const level = bar.style.getPropertyValue('--level');
            bar.style.transform = `scaleX(${level})`;
            bar.dataset.animated = 'true';
            observer.unobserve(bar);
          }
        });
      });
      observer.observe(bar);
    });
  }

  const renderSkills = (skills: SkillItem[]) => {
    if (!tabContainer || !section || !Array.isArray(skills) || skills.length === 0) {
      return;
    }

    const grouped = skills.reduce<Record<string, SkillItem[]>>((acc, skill) => {
      const category = skill?.acf?.category || 'Otros';
      if (!acc[category]) acc[category] = [];
      acc[category].push(skill);
      return acc;
    }, {});

    const categories = Object.keys(grouped);
    if (categories.length === 0) return;

    tabContainer.innerHTML = '';

    categories.forEach((cat, i) => {
      const tab = document.createElement('button');
      tab.dataset.category = cat;
      tab.className =
        'skill-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all duration-200 ' +
        (i === 0
          ? 'bg-secondary-container text-on-secondary-container'
          : 'bg-surface-high text-on-surface-variant hover:bg-surface-highest hover:text-on-surface');
      tab.textContent = cat;
      tabContainer.appendChild(tab);
    });

    section.querySelectorAll<HTMLDivElement>('.skill-panel').forEach((panel) => panel.remove());

    categories.forEach((cat, i) => {
      const panel = document.createElement('div');
      panel.dataset.panel = cat;
      panel.className =
        `skill-panel ${i !== 0 ? 'hidden ' : ''}` +
        'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4';

      grouped[cat].forEach((skill: SkillItem, j: number) => {
        const level = Number(skill?.acf?.level ?? 0);

        const card = document.createElement('div');
        card.className =
          'reveal group bg-surface-low hover:bg-surface-highest rounded-xl p-5 transition-all duration-300 ghost-border';
        card.style.animationDelay = `${j * 60}ms`;

        const header = document.createElement('div');
        header.className = 'flex items-center justify-between mb-3';

        const title = document.createElement('span');
        title.className = 'font-body text-sm font-medium text-on-surface';
        title.textContent = skill?.title?.rendered ?? 'Habilidad';

        const pct = document.createElement('span');
        pct.className = 'font-mono text-xs text-primary';
        pct.textContent = `${level}%`;

        header.append(title, pct);

        const barWrap = document.createElement('div');
        barWrap.className = 'h-1 bg-outline-variant/20 rounded-full overflow-hidden';

        const bar = document.createElement('div');
        bar.className =
          'skill-bar h-full bg-primary rounded-full origin-left scale-x-0 transition-transform duration-700';
        bar.style.setProperty('--level', String(Math.max(0, Math.min(100, level)) / 100));
        bar.style.setProperty('transition-timing-function', 'var(--ease-expo)');
        barWrap.appendChild(bar);

        card.append(header, barWrap);
        panel.appendChild(card);
      });

      section.querySelector('.max-w-content')?.appendChild(panel);
    });

    bindTabs();
    animateBars();
  };

  const loadSkills = async () => {
    const apiBase = section?.getAttribute('data-api-base')?.replace(/\/$/, '');
    if (!apiBase) return;

    try {
      const response = await fetch(
        `${apiBase}/wp/v2/skill?per_page=100&_fields=id,title,acf`,
      );
      if (!response.ok) return;

      const skills = (await response.json()) as SkillItem[];
      renderSkills(skills);
    } catch {
      // Mantiene fallback estatico si hay error de API/CORS.
    }
  };

  bindTabs();
  animateBars();
  loadSkills();
</script>